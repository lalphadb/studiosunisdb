

echo '{"audit_date": "'$(date -u +"%Y-%m-%dT%H:%M:%SZ")'","files": {' > "$output_file"

# Analyse des components
components_dir="resources/views/components"
components=$(ls -1 "$components_dir"/*.blade.php 2>/dev/null | xargs -n 1 basename | sed 's/.blade.php//')
components_data=""
for component in $components; do
    usage=$(grep -r -E "<x-$component[^a-zA-Z-]|<x-$component>|<x[^:]*::$component" resources/views 2>/dev/null)
    usage_count=$(echo "$usage" | wc -l)
    files_using=$(echo "$usage" | awk -F: '{print $1}' | sort | uniq | jq -R . | jq -s .)
    tailwind_classes=$(grep -oE 'class="[^"]*"' "$components_dir/$component.blade.php" 2>/dev/null | sed 's/class="//;s/"$//' | tr ' ' '\n' | sort | uniq | jq -R . | jq -s .)
    components_data+=",\"$component\": {\"usage_count\": $usage_count, \"files_using\": $files_using, \"tailwind_classes\": $tailwind_classes}"
done
components_data=${components_data#,}
echo "\"components\": {$components_data}," >> "$output_file"

# Analyse des vues (excluant components)
views_data=""
views=$(find resources/views -type f -name "*.blade.php" ! -path "resources/views/components/*" 2>/dev/null | xargs -n 1 basename | sed 's/.blade.php//')
for view in $views; do
    usage=$(grep -r -E "view\(['\"][a-zA-Z0-9_\-/]*$view['\"]|return\s+$view\s+to" routes app/Http/Controllers 2>/dev/null)
    usage_count=$(echo "$usage" | wc -l)
    files_using=$(echo "$usage" | awk -F: '{print $1}' | sort | uniq | jq -R . | jq -s .)
    includes=$(grep -r -E "@include\(['\"][a-zA-Z0-9_\-\.]*['\"]|@extends\(['\"][a-zA-Z0-9_\-\.]*['\"]" "resources/views/$view.blade.php" 2>/dev/null | awk -F"['\"]" '{print $2}' | jq -R . | jq -s .)
    views_data+=",\"$view\": {\"usage_count\": $usage_count, \"files_using\": $files_using, \"includes\": $includes}"
done
views_data=${views_data#,}
echo "\"views\": {$views_data}," >> "$output_file"

# Analyse des controllers
controllers_data=""
controllers=$(find app/Http/Controllers -type f -name "*.php" ! -name "*.backup" 2>/dev/null | xargs -n 1 basename | sed 's/.php//')
for controller in $controllers; do
    usage=$(grep -r -E "[\"\']$controller[\"\']|use App\\\\Http\\\\Controllers.*$controller" routes 2>/dev/null)
    usage_count=$(echo "$usage" | wc -l)
    files_using=$(echo "$usage" | awk -F: '{print $1}' | sort | uniq | jq -R . | jq -s .)
    models_used=$(grep -r -E "use App\\\\Models.*;" "app/Http/Controllers/$controller.php" 2>/dev/null | awk -F"App\\\\Models\\\\" '{print $2}' | sed 's/;//' | jq -R . | jq -s .)
    controllers_data+=",\"$controller\": {\"usage_count\": $usage_count, \"files_using\": $files_using, \"models_used\": $models_used}"
done
controllers_data=${controllers_data#,}
echo "\"controllers\": {$controllers_data}," >> "$output_file"

# Analyse des modèles
models_data=""
models=$(find app/Models -type f -name "*.php" ! -name "*.backup" 2>/dev/null | xargs -n 1 basename | sed 's/.php//')
for model in $models; do
    usage=$(grep -r -E "use App\\\\Models.*$model|App\\\\Models\\\\$model" app/Http/Controllers app/Policies 2>/dev/null)
    usage_count=$(echo "$usage" | wc -l)
    files_using=$(echo "$usage" | awk -F: '{print $1}' | sort | uniq | jq -R . | jq -s .)
    policies_used=$(grep -r -E "use App\\\\Models.*$model" app/Policies 2>/dev/null | awk -F: '{print $1}' | xargs -n 1 basename | jq -R . | jq -s .)
    models_data+=",\"$model\": {\"usage_count\": $usage_count, \"files_using\": $files_using, \"policies_used\": $policies_used}"
done
models_data=${models_data#,}
echo "\"models\": {$models_data}," >> "$output_file"

# Analyse des routes
routes_data=""
routes=$(find routes -type f -name "*.php" ! -name "*.backup" 2>/dev/null | xargs -n 1 basename | sed 's/.php//')
for route in $routes; do
    controllers_used=$(grep -r -E "use App\\\\Http\\\\Controllers.*;|->controller\(['\"][a-zA-Z0-9_\\]*['\"\]" "routes/$route.php" 2>/dev/null | awk -F"App\\\\Http\\\\Controllers\\\\|['\"]" '{print $2}' | sed 's/;//' | sort | uniq | jq -R . | jq -s .)
    routes_data+=",\"$route\": {\"controllers_used\": $controllers_used}"
done
routes_data=${routes_data#,}
echo "\"routes\": {$routes_data}," >> "$output_file"

# Analyse des fichiers inutilisés
unused_data=""
unused_files=$(find . -type f \( -name "*.backup" -o -path "./backup_*/*" -o -path "./resources/views/components/actions-*.blade.php" -o -name "empty-state.blade.php" -o -name "admin-layout.blade.php" \) 2>/dev/null | xargs -n 1 basename)
for file in $unused_files; do
    usage=$(grep -r "$file" . --exclude-dir={vendor,node_modules,storage,public,backup_*} 2>/dev/null)
    usage_count=$(echo "$usage" | wc -l)
    files_using=$(echo "$usage" | awk -F: '{print $1}' | sort | uniq | jq -R . | jq -s .)
    unused_data+=",\"$file\": {\"usage_count\": $usage_count, \"files_using\": $files_using}"
done
unused_data=${unused_data#,}
echo "\"unused_files\": {$unused_data}," >> "$output_file"

# Fichiers standardisants
standardizing_data='{
    "layouts": ["admin.blade.php", "guest.blade.php", "app.blade.php", "membre.blade.php"],
    "partials": ["admin-navigation.blade.php", "footer.blade.php"],
    "components": ["module-header.blade.php", "admin-icon.blade.php", "dark-mode-toggle.blade.php"]
}'

# Fichiers supprimables
safe_deletion='[
    "actions-ecoles.blade.php", "actions-cours.blade.php", "actions-seminaires.blade.php",
    "actions-sessions.blade.php", "actions-users.blade.php", "empty-state.blade.php",
    "admin-layout.blade.php", "dashboard.blade.php.backup", "app.css.backup",
    "Ecole.php.backup", "User.php.backup", "SecurityAuditCommand.php.backup"
]'

# Fichiers de backup (dossiers)
backup_dirs='[
    "backup_components_20250703_101128", "backup_components_inutilises_20250701",
    "backup_doublons_20250701", "backup_seeders_20250701",
    "backup_seeders_redondants_20250701", "backup_vues_ceintures_20250701"
]'

# Clôture du JSON
echo "\"standardizing_files\": $standardizing_data, \"safe_deletion_candidates\": $safe_deletion, \"backup_dirs\": $backup_dirs}" >> "$output_file"
echo "}" >> "$output_file"

# Formater le JSON
jq . "$output_file" > "$output_file.tmp" && mv "$output_file.tmp" "$output_file"

# Résumé console
echo "✅ Audit terminé. Rapport sauvegardé dans $output_file"
echo "📊 Résumé :"
echo "  - Components analysés : $(echo "$components" | wc -w)"
echo "  - Vues analysées : $(echo "$views" | wc -w)"
echo "  - Controllers analysés : $(echo "$controllers" | wc -w)"
echo "  - Modèles analysés : $(echo "$models" | wc -w)"
echo "  - Routes analysées : $(echo "$routes" | wc -w)"
echo "  - Fichiers inutilisés trouvés : $(echo "$unused_files" | wc -w)"
echo "  - Candidats à la suppression : $(echo "$safe_deletion" | jq '. | length')"
echo "  - Dossiers de backup : $(echo "$backup_dirs" | jq '. | length')"

# Commandes de validation
echo "🔍 Commandes de validation :"
echo "  # Vérifier l’usage des components"
echo "  grep -r -E '<x-actions-ecoles|<x-actions-cours|<x-actions-seminaires|<x-actions-sessions|<x-actions-users|<x-empty-state|<x-admin-layout' resources/views"
echo "  # Vérifier les fichiers de backup"
echo "  grep -r -E 'dashboard.blade.php.backup|app.css.backup|Ecole.php.backup|User.php.backup|SecurityAuditCommand.php.backup' . --exclude-dir={vendor,node_modules,storage,public,backup_*}"
echo "  # Vérifier les seeders redondants"
echo "  grep -r -E 'AdminUserSeeder|PermissionSeeder' database/seeders/DatabaseSeeder.php"
echo "  # Vérifier le rapport JSON"
echo "  cat $output_file | jq ."

# Commandes de suppression (à exécuter après validation)
echo "🗑️ Commandes de suppression (après validation) :"
echo "  rm resources/views/components/{actions-ecoles,actions-cours,actions-seminaires,actions-sessions,actions-users,empty-state,admin-layout}.blade.php"
echo "  rm -r backup_components_20250703_101128 backup_components_inutilises_20250701 backup_doublons_20250701 backup_seeders_20250701 backup_seeders_redondants_20250701 backup_vues_ceintures_20250701"
echo "  rm resources/views/{dashboard.blade.php.backup,admin.php.backup,web.php.backup}"
echo "  rm resources/css/app.css.backup"
echo "  rm app/Models/{Ecole.php.backup,User.php.backup}"
echo "  rm app/Console/Commands/SecurityAuditCommand.php.backup"
```
