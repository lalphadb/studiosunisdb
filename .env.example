# STUDIOSDB ENTERPRISE - Configuration
# ⚠️  NE JAMAIS COMMITER CE FICHIER AVEC DES VRAIES VALEURS!

APP_NAME="StudiosDB Enterprise"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# Base de données
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=studiosdb
DB_USERNAME=root
DB_PASSWORD=ChangeMeInProduction!

# Sécurité - 2FA (OBLIGATOIRE en production)
ENFORCE_2FA_SUPERADMIN=true
ENFORCE_2FA_ADMIN=true
FORTIFY_TWO_FACTOR_AUTHENTICATION=true

# Session & Sécurité
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_DRIVER=file

# Monitoring & Alertes
LOG_CHANNEL=stack
LOG_LEVEL=debug
SUPERADMIN_LOG_CHANNEL=superadmin
ALERT_EMAIL_CRITICAL=security@studiosdb.com
ALERT_EMAIL_SUPERADMIN=admin@studiosdb.com

# Limites de sécurité
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15
MAX_USERS_PER_ECOLE=1000

# Features
TELESCOPE_ENABLED=true
TELESCOPE_PATH=telescope
